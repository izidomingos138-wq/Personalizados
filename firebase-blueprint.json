{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Item à venda na loja",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "promoPrice": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "stock": { "type": "number" },
        "featured": { "type": "boolean" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" }
      },
      "required": ["id", "name", "price", "category", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "Pedido feito por um cliente",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerAddress": { "type": "string" },
        "items": { "type": "array" },
        "totalPrice": { "type": "number" },
        "paymentStatus": { "type": "string" },
        "deliveryStatus": { "type": "string" },
        "createdAt": { "type": "string" },
        "pixCode": { "type": "string" }
      },
      "required": ["id", "userId", "customerName", "customerPhone", "items", "totalPrice", "paymentStatus"]
    },
    "Banner": {
      "title": "PromoBanner",
      "description": "Banner promocional da home",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "imageUrl": { "type": "string" },
        "title": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["id", "imageUrl", "title", "active"]
    },
    "Coupon": {
      "title": "PromoCoupon",
      "description": "Cupom de desconto",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "discountType": { "type": "string" },
        "discountValue": { "type": "number" },
        "minPurchase": { "type": "number" },
        "active": { "type": "boolean" }
      },
      "required": ["id", "code", "discountType", "discountValue", "active"]
    },
    "Review": {
      "title": "ProductReview",
      "description": "Avaliação de um produto",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "productId", "userId", "userName", "rating", "comment"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Coleção de produtos cadastrados"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Coleção contendo todos os pedidos realizados"
    },
    "/banners/{bannerId}": {
      "schema": "Banner",
      "description": "Coleção contendo os banners da landing page"
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Coleção contendo os cupons de desconto ativos"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Coleção de avaliações dos produtos"
    }
  }
}
